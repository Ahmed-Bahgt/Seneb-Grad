# Tamren Tech — Production Environment Variables
# Copy this file to .env on the server and fill in the values

# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=tamren_db
POSTGRES_USER=tamren_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── App Security ──────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_RANDOM_SECRET_KEY_HERE

# ── AI / ML API Keys ──────────────────────────────────────────
GEMINI_API_KEY=CHANGE_ME_YOUR_GEMINI_KEY_HERE
OPENROUTER_API_KEY=CHANGE_ME_YOUR_OPENROUTER_KEY_HERE
